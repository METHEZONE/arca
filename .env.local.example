# ─────────────────────────────────────────────────────────────────────────
# ARCA configuration. Copy to `.env.local` and fill in what you have.
# ARCA runs in a full demo flow with ZERO keys, then activates each layer
# the moment its key is present. Nothing here is required to see the product.
# ─────────────────────────────────────────────────────────────────────────

# ── Transcription + speaker diarization (화자분리) ──────────────────────────
# Defaults to auto: OpenAI diarized STT first, then ElevenLabs Scribe fallback.
# Use TRANSCRIPTION_PROVIDER=elevenlabs when you need larger-file fallback,
# or demo when you want zero external calls.
# TRANSCRIPTION_PROVIDER=auto        # auto | openai | elevenlabs | demo
OPENAI_API_KEY=
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
ELEVENLABS_API_KEY=
# ELEVENLABS_STT_MODEL=scribe_v2

# ── Analysis: notes, decisions, action plans ──────────────────────────────
# Provide Anthropic and/or reuse OPENAI_API_KEY above. ANALYSIS_PROVIDER picks
# which one runs. Defaults: prefer Claude, then OpenAI, then demo.
ANTHROPIC_API_KEY=
# ANALYSIS_PROVIDER=claude        # claude | openai
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_NOTES_MODEL=gpt-5.5

# ── Obsidian (write markdown into a vault folder you share with the team) ──
# Point this at your local/synced Obsidian vault directory.
OBSIDIAN_VAULT_PATH=
# OBSIDIAN_SUBFOLDER=ARCA

# ── Notion (one page per memory in a shared database) ─────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Slack (post summary + action items to a channel) ──────────────────────
# Easiest: an incoming webhook URL. Or use a bot token + channel.
SLACK_WEBHOOK_URL=
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL=#arca

# ── THE ZONE BIO Slack agent (mentions + DMs) ─────────────────────────────
# Slack Events API endpoint: /api/slack/agent
# Use a Slack App bot token, not a personal account token.
SLACK_SIGNING_SECRET=
SLACK_APP_BOT_USER_ID=
# Your personal Slack member ID. Used to detect messages that mention you,
# even when they do not mention the ARCA app directly.
SLACK_AGENT_OWNER_USER_ID=
# Restrict channel mention replies to channel IDs, comma-separated.
# SLACK_AGENT_MENTION_CHANNELS=C0123456789,C9876543210
# Safe defaults: queue drafts instead of posting automatically.
# SLACK_AGENT_DRY_RUN=true
# SLACK_AGENT_AUTO_REPLY=false
# SLACK_AGENT_REQUIRE_APPROVAL=true
# SLACK_AGENT_MODEL_TIMEOUT_MS=1500

# ── Auto-push behavior ────────────────────────────────────────────────────
# Comma list of targets to push to automatically after each recording.
# Defaults to every configured target. Use `none` to disable auto-push.
# AUTO_PUSH_TARGETS=obsidian,notion,slack

# ── Hardware ingest ────────────────────────────────────────────────────────
# Optional shared secret for ESP32-S3 / recorder uploads.
# Send it as `x-arca-device-token` when POSTing to /api/hardware/ingest.
# Set this before exposing the app beyond your laptop/local network.
# ARCA_INGEST_TOKEN=

# ── ARCA Ring (/ring — NFC tap page) ──────────────────────────────────────
# Connect submissions + waitlist signups are appended to data/ring/*.jsonl
# and delivered by email (Resend) and/or the Slack webhook above.
# On Vercel the file DB is ephemeral (/tmp) — set RESEND_API_KEY there.
# Free Resend tier can send from onboarding@resend.dev to your own inbox.
RESEND_API_KEY=
# RING_NOTIFY_EMAIL=foxish@thezonebio.com
# RING_FROM_EMAIL=ARCA Ring <onboarding@resend.dev>

# ── Storage ───────────────────────────────────────────────────────────────
# Where the second brain is persisted (gitignored).
# ARCA_DATA_DIR=data
